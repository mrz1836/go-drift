# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-drift
# Load Order: 90 (loaded last before 99-local.env, overrides all defaults)
#
# This file contains project-specific configuration that overrides defaults
# from earlier env files (00-core, 10-*, 20-*). Use this for settings that
# are unique to this repository.
#
# Maintainer: @mrz1836
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER & SETTINGS
# ================================================================================================

# Use Codecov as the coverage provider (overrides default: internal)
GO_COVERAGE_PROVIDER=codecov

# Require Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS
# ================================================================================================

# Path exclusions aligned with codecov.yml ignore rules
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/,docs/

# ================================================================================================
# 🛡️ SECURITY CVE EXCLUSIONS
# ================================================================================================

# Nancy CVE exclusions (overrides 10-security.env defaults)
NANCY_EXCLUDES=CVE-2026-5160

# MageX/Govulncheck CVE exclusions (overrides 10-security.env defaults)
MAGE_X_CVE_EXCLUDES=CVE-2026-5160
